# Baize Wiki — Environment Configuration
# Copy this file to .env and fill in your values.
# These override values in baize.yaml.

# ── Catalog (LLM Summaries) ──
# Backend: local (first-paragraph) or remote (LLM API)
# BAIZE_CATALOG_BACKEND=remote

# Remote API endpoint (e.g. LM Studio, DeepSeek, OpenAI)
# BAIZE_CATALOG_ENDPOINT=http://localhost:1234/v1

# Remote model name
# BAIZE_CATALOG_MODEL=qwen/qwen3.5-9b

# API key (required for cloud providers like DeepSeek/OpenAI)
# BAIZE_CATALOG_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── Vector (Semantic Search) ──
# Mode: local (feature hashing) or remote (embedding API)
# BAIZE_VECTOR_MODE=remote

# Remote API endpoint (e.g. LM Studio with bge-m3)
# BAIZE_VECTOR_ENDPOINT=http://localhost:1234/v1

# Remote model name
# BAIZE_VECTOR_MODEL=text-embedding-baai-bge-m3-568m:2

# API key (required for cloud providers)
# BAIZE_VECTOR_API_KEY=sk-xxxxxxxxxxxxxxxx
