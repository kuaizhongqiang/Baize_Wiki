{
  "permissions": {
    "allow": [
      "go build",
      "go test",
      "go vet",
      "go mod tidy",
      "go fmt",
      "git status",
      "git diff",
      "git log",
      "git add",
      "git commit",
      "mkdir -p",
      "rm -rf bin/"
    ]
  },
  "mcpServers": {
    "codegraph": {
      "command": "codegraph",
      "args": ["mcp"],
      "disabled": false,
      "autoApprove": ["codegraph_search", "codegraph_context", "codegraph_callers", "codegraph_callees", "codegraph_node", "codegraph_explore"]
    }
  }
}
